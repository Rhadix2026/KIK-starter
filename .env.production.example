# ─────────────────────────────────────────────────────────────────────────────
# KIK-Starter — Productie omgevingsconfiguratie
# ─────────────────────────────────────────────────────────────────────────────
# Kopieer dit bestand op de server naar: /opt/kik-app/.env.production
# Vul alle waarden in. Dit bestand NOOIT in Git committen.
#
# Gebruik:
#   docker compose -p kik-prod -f docker-compose.prod.yml --env-file .env.production up -d
# ─────────────────────────────────────────────────────────────────────────────

GHCR_ORG=rhadix2026

# Image-versie die draait (wordt door deploy-production.yml gezet op de versie-tag)
KIK_VERSION=latest

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=kik
DB_PASSWORD=verander_dit_naar_een_sterk_productie_wachtwoord
DB_NAME=kik_starter

# ── Auth ──────────────────────────────────────────────────────────────────────
# Genereer met: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=verander_dit_naar_een_32byte_secret
KIK_ADMIN_EMAIL=admin@kik-starter.nl
KIK_ADMIN_PASSWORD=verander_dit_naar_een_sterk_admin_wachtwoord

# ── Poorten (ANDERS dan staging en dan de validation-app) ─────────────────────
FRONTEND_PORT=5176
BACKEND_PORT=8012

# ── Fuseki triple store (interne service) ─────────────────────────────────────
FUSEKI_PASSWORD=kik-prod-admin

# ── Uitwisselprofielen-bron (optioneel) ───────────────────────────────────────
PROFILES_URL=
