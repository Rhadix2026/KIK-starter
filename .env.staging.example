# ─────────────────────────────────────────────────────────────────────────────
# KIK-Starter — Staging omgevingsconfiguratie
# ─────────────────────────────────────────────────────────────────────────────
# Kopieer dit bestand op de server naar: /opt/kik-app/.env.staging
# Vul alle waarden in. Dit bestand NOOIT in Git committen.
#
# Gebruik:
#   docker compose -p kik-staging -f docker-compose.staging.yml --env-file .env.staging up -d
# ─────────────────────────────────────────────────────────────────────────────

# GitHub Container Registry-organisatie
GHCR_ORG=rhadix2026

# ── Database (ANDERE waarden dan productie!) ──────────────────────────────────
STAGING_DB_USER=kik_staging
STAGING_DB_PASSWORD=verander_dit_naar_een_sterk_staging_wachtwoord
STAGING_DB_NAME=kik_staging

# ── Auth ──────────────────────────────────────────────────────────────────────
# Genereer met: python -c "import secrets; print(secrets.token_hex(32))"
STAGING_JWT_SECRET_KEY=verander_dit_naar_een_32byte_secret
STAGING_ADMIN_EMAIL=admin@kik-starter.nl
STAGING_ADMIN_PASSWORD=verander_dit_naar_een_sterk_admin_wachtwoord

# ── Poorten (ANDERS dan productie 5176/8012 en dan de validation-app) ─────────
STAGING_FRONTEND_PORT=5177
STAGING_BACKEND_PORT=8013

# ── Fuseki triple store (interne service) ─────────────────────────────────────
STAGING_FUSEKI_PASSWORD=kik-staging-admin

# ── Uitwisselprofielen-bron (optioneel) ───────────────────────────────────────
# Leeg = ingebouwde set. Vul de Rhadix-validation profielen-API in om die te gebruiken.
STAGING_PROFILES_URL=
